{
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Grep(*)",
      "Glob(*)",
      "Task(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Skill(*)",
      "NotebookEdit(*)"
    ],
    "deny": [
      "Bash(rm -rf __USER_HOME__/.claude/*)",
      "Bash(rm -rf __USER_HOME__/projects/*)",
      "Bash(rm -rf /*)",
      "Bash(format *)",
      "Bash(* --delete-all *)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(* DROP TABLE *)",
      "Bash(* DROP DATABASE *)",
      "Bash(* TRUNCATE TABLE *)",
      "Bash(chmod 777 *)",
      "Bash(* > /dev/null 2>&1 &)",
      "Bash(npm publish*)",
      "Bash(pip install * --break-system-packages*)",
      "Bash(* curl * | bash*)",
      "Bash(* curl * | sh*)",
      "Bash(* wget * | bash*)",
      "Edit(**/*.test.py)",
      "Edit(**/*.test.ts)",
      "Edit(**/*.spec.ts)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(docker rm *)",
      "Bash(kubectl delete *)",
      "Edit(.env*)",
      "Edit(**/*_test.py)",
      "Edit(**/*tests.py)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/session_start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/pre_compact.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/pre_commit_guard.py",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/read_before_edit.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/security_verify.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__*",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/input_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/mcp_circuit_breaker.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__context7|mcp__claude_ai|mcp__ollama|mcp__ncbi|mcp__uniprot|mcp__pubmed|mcp__semantic|mcp__bioRxiv",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/mcp_locality_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/scripts/redact.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__*",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/mcp_circuit_breaker_post.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/async_wrapper.py __PYTHON_CMD__ __CLAUDE_HOME__/hooks/post_format.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/plan_mode_guard.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Skill|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/drift_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/evidence_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/spot_check_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/memory_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/checkpoint_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/post_commit_memory.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/async_wrapper.py __PYTHON_CMD__ __CLAUDE_HOME__/hooks/pattern_extractor.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/keyword_router.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/thinking_level.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/async_wrapper.py __PYTHON_CMD__ __CLAUDE_HOME__/hooks/session_save.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/async_wrapper.py __PYTHON_CMD__ __CLAUDE_HOME__/hooks/webhook_notify.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -Command \"[console]::beep(800, 300)\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/permission_policy.py",
            "timeout": 5
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": ".env|.envrc|.env.local|.env.development",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/env_reload.py",
            "timeout": 5
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/direnv_loader.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/agent_lifecycle.py --start",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/agent_lifecycle.py --stop",
            "timeout": 10
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/config_audit.py",
            "timeout": 5
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON_CMD__ __CLAUDE_HOME__/hooks/team_rebalance.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "spinnerTipsEnabled": true,
  "spinnerTipsOverride": {
    "tips": [
      "git worktree add ../experiment — isolated branch without stash",
      "ruff check --fix . — auto-fix lint in 0.1s",
      "pytest -x --lf — rerun only failed tests, stop on first failure",
      "claude mcp list — check which MCP servers are connected",
      "structlog > print() — structured logs, JSON-ready",
      "Pydantic model_validate() — validation at entry is cheaper than debugging at exit",
      "/compact when context >50% — save tokens without losing the thread",
      "Evidence markers: [VERIFIED] > [INFERRED] > [UNKNOWN]",
      "pytest --cov=src --cov-fail-under=80 — coverage gate right in CI",
      "Plan Mode (3+ files) saves 40% of rework time",
      "TDD: RED > GREEN > REFACTOR. Tests after code test implementation, not requirements",
      "Circuit Breaker: 3 MCP failures > auto-fallback to local tools",
      "80/20: 20% of tests cover 80% of bugs",
      "Parallel agents (reviewer + sec-auditor) = 2x review speed",
      "pre_commit_guard blocks rm -rf, push --force, DROP TABLE — your safety net",
      "Async hooks (post_format, pattern_extractor) — format & learn without blocking",
      "PermissionRequest hook auto-approves Read/Glob/Grep — 75% fewer prompts",
      "security_verify auto-warns on .env/auth/payment file edits",
      "webhook_notify sends Slack/Telegram alerts on session events",
      "Agent Teams: review-squad = reviewer + sec-auditor in parallel",
      "Persistent agent memory — reviewer remembers codebase patterns between sessions"
    ],
    "excludeDefault": false
  },
  "statusLine": {
    "type": "command",
    "command": "__PYTHON_CMD__ __CLAUDE_HOME__/statusline.py"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": false,
    "github@claude-plugins-official": false
  },
  "autoUpdatesChannel": "stable"
}
