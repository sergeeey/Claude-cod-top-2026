{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Grep(*)",
      "Glob(*)",
      "Task(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Skill(*)",
      "NotebookEdit(*)"
    ],
    "deny": [
      "Bash(rm -rf $HOME/.claude/*)",
      "Bash(rm -rf $HOME/projects/*)",
      "Bash(rm -rf /*)",
      "Bash(format *)",
      "Bash(* --delete-all *)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(* DROP TABLE *)",
      "Bash(* DROP DATABASE *)",
      "Bash(* TRUNCATE TABLE *)",
      "Bash(chmod 777 *)",
      "Bash(* > /dev/null 2>&1 &)",
      "Bash(npm publish*)",
      "Bash(pip install * --break-system-packages*)",
      "Bash(* curl * | bash*)",
      "Bash(* curl * | sh*)",
      "Bash(* wget * | bash*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/session_start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/pre_compact.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/pre_commit_guard.py",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/read_before_edit.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__*",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/input_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/mcp_circuit_breaker.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__context7|mcp__claude_ai|mcp__ollama|mcp__ncbi|mcp__uniprot|mcp__pubmed|mcp__semantic|mcp__bioRxiv",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/mcp_locality_guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python $HOME/.claude/scripts/redact.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__*",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/mcp_circuit_breaker_post.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/post_format.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/plan_mode_guard.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Skill|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/drift_guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/memory_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/checkpoint_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/post_commit_memory.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/pattern_extractor.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python $HOME/.claude/hooks/session_save.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -Command \"[console]::beep(800, 300)\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "spinnerTipsEnabled": true,
  "spinnerTipsOverride": {
    "tips": [
      "💡 git worktree add ../experiment — isolated branch without stash",
      "💡 ruff check --fix . — auto-fix lint in 0.1s (vs flake8 + isort)",
      "💡 pytest -x --lf — rerun only failed tests, stop on first failure",
      "💡 claude mcp list — check which MCP servers are actually connected",
      "💡 git log --oneline -20 | grep fix: — quick overview of recent bugfixes",
      "💡 python -m pytest --co -q — show which tests would run, without running them",
      "💡 Ctrl+R in Claude Code — search through prompt history",
      "💡 structlog > print() — structured logs, JSON-ready, no refactor later",
      "💡 git diff --stat HEAD~5 — overview of changes in the last 5 commits",
      "💡 Pydantic model_validate() — validation at entry is cheaper than debugging at exit",
      "💡 /compact when context >50% — save tokens without losing the thread",
      "💡 Evidence markers: [VERIFIED] > [INFERRED] > [UNKNOWN] — honesty is cheaper than bugs",
      "💡 pytest --cov=src --cov-fail-under=80 — coverage gate right in CI",
      "💡 git stash -p — stash selectively, not everything at once",
      "💡 Plan Mode (3+ files) saves 40% of rework time",
      "💡 claude --resume — continue last session with full context",
      "💡 mypy --strict src/ — types catch bugs before runtime",
      "💡 WebSearch costs tokens. Local Grep = 0 tokens",
      "💡 TDD: RED → GREEN → REFACTOR. Tests after code test implementation, not requirements",
      "💡 /cost — check spending before closing the session",
      "⚡ Claude Code hooks execute 100% of the time, CLAUDE.md instructions ~80%. Hooks > rules",
      "⚡ Circuit Breaker: 3 MCP failures → auto-fallback to local tools",
      "⚡ 80/20: 20% of tests cover 80% of bugs — cover happy path + edge cases",
      "⚡ Scope Fence in activeContext.md — scope creep protection via drift_guard.py",
      "⚡ Parallel agents (reviewer + sec-auditor) = 2x review speed",
      "⚡ Progressive Disclosure: 500 tok baseline vs 5000-7000 in monolithic configs",
      "⚡ pre_commit_guard blocks rm -rf, push --force, DROP TABLE — your safety net",
      "⚡ Pattern tags [REPEAT]/[AVOID]/[×N] — a system that learns from its own mistakes",
      "⚡ «Premature optimization is the root of all evil» — Donald Knuth",
      "⚡ «Any fool can write code a computer can understand. Good programmers write code humans can understand.» — Martin Fowler"
    ],
    "excludeDefault": false
  },
  "statusLine": {
    "type": "command",
    "command": "python $HOME/.claude/statusline.py"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": false,
    "github@claude-plugins-official": false
  },
  "autoUpdatesChannel": "stable"
}
